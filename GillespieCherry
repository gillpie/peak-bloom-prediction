#Temperature
historic_temperatures= bind_rows(
  kyototemp      |> mutate(location = "kyoto"),
  washdc         |> mutate(location = "washingtondc"),
  vancouvertemp  |> mutate(location = "vancouver"),
  newyorkcity    |> mutate(location = "newyorkcity"),
  liestaltemp    |> mutate(location = "liestal"))

historic_temperatures= historic_temperatures |>
  mutate(
    TMAX = TMAX / 10,
    TMIN = TMIN / 10,
    TAVG = TAVG / 10)

#December-February
avg_winter_temp= historic_temperatures |>
  mutate(
    year = case_when(
      month(Date) < 3  ~ year(Date),
      month(Date) == 12 ~ year(Date) + 1,
      TRUE ~ NA_integer_
    )
  ) |>
  filter(!is.na(year), year >= 1970) |>
  filter(month(Date) %in% c(12, 1, 2)) |>
  group_by(location, year) |>
  summarize(
    avg_tmax = mean(TMAX, na.rm = TRUE),
    .groups = "drop")

avg_winter_temp |>
  ggplot(aes(x = year, y = avg_tmax)) +
  geom_line() +
  facet_grid(rows = vars(location)) +
  labs(y = "Average Winter Tmax (°C)")

ls_fit_with_temp=cherry |>
  inner_join(avg_winter_temp,
             by = c("location", "year")) |>
  lm(bloom_doy ~ location + year + avg_tmax,
     data = _)

cherry_grid= expand_grid(
